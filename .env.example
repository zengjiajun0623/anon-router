# OpenRouter credential; required and intentionally blank in this template.
OPENROUTER_API_KEY=
# Watcher-to-router authentication secret; generate a strong random value.
CREDIT_SECRET=
# Paid inference API base URL.
UPSTREAM=https://openrouter.ai/api/v1
# Keep the unauthenticated development faucet disabled in production.
DEV_FAUCET=0
# Maximum credits issued by one faucet request if explicitly enabled locally.
FAUCET_MAX=500000
# Keep the unescrowed M4a channel lane disabled in production.
CHANNEL_LANE_ENABLED=0
# Maximum USD sent to paid inference per UTC day; zero disables the breaker.
DAILY_USD_CAP=25
# Global anonymous account creations allowed in each rolling minute.
ACCOUNT_RATE_PER_MIN=120
# Credits granted for one deposited ETH.
CREDITS_PER_ETH=10000000
# USD value represented by one internal credit.
CREDIT_USD=0.0001
# Multiplier applied to upstream cost when charging credits.
MARKUP=1.0
# Minimum credits required before an X-Cash inference request.
MIN_PREPAY=500
# On-chain vault contract address; set to the deployed contract.
VAULT_ADDRESS=
# Ethereum JSON-RPC endpoint used for chain access.
CHAIN_RPC=http://127.0.0.1:8545
# Blocks the watcher waits before crediting a deposit.
CONFIRMATIONS=3
# Persistent path for the mint master secret; mount this directory durably.
MINT_MASTER_PATH=/data/anon-router/mint_master.hex
# Free local OpenAI-compatible inference endpoint.
LOCAL_UPSTREAM=http://127.0.0.1:11435/v1
# Public router URL returned to newly created accounts.
PUBLIC_BASE_URL=http://127.0.0.1:8402
# Fixed credits charged per enabled channel request.
CHANNEL_PRICE=50
# Channel dispute window in days.
CHANNEL_TAU=7
# Channel recipient XMSS tree height.
CHANNEL_HEIGHT=12
# On-chain channel escrow contract address; leave blank until deployed.
CONFETTI_ADDRESS=
